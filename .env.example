# Local-only configuration template.
# Copy to `.env` when you need live integrations. Never commit `.env`.

# Salesforce / BigQuery read-only access
GOOGLE_APPLICATION_CREDENTIALS=
BIGQUERY_PROJECT_ID=
SALESFORCE_TERRITORY_DATASET=

# Optional browser/session overrides
SALES_NAV_SESSION_MODE=persistent
SALES_NAV_STORAGE_STATE_PATH=runtime/sessions/linkedin-state.json
SALES_NAV_USER_DATA_DIR=runtime/browser-profile/sales-nav-driver

# Optional Browser Harness command override
BROWSER_HARNESS_COMMAND=
